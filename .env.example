# ComunicaPA — Esempio configurazione
# Copia questo file in .env e adatta i valori al tuo ambiente.
# Non committare mai .env con credenziali reali nel repository!

# ── Porte host (mappate dal docker-compose ai container) ──────────────────────
# Porta host esposta per il backend NestJS
BACKEND_PORT=8080

# Porta host esposta per il portale operatori PA
ADMIN_PORT=3000

# Porta host esposta per il portale cittadino
CITIZEN_PORT=3001

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Host del DB: "postgres" = nome del service Docker Compose in dev
# In prod: hostname o IP del server PostgreSQL esterno
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=comunicapa
POSTGRES_PASSWORD=comunicapa_dev_password
POSTGRES_DB=comunicapa_db

# URL completo per ORM (TypeORM, Prisma).
# In dev costruita automaticamente dai valori sopra.
# In prod: sovrascrivere con la stringa di connessione completa.
DATABASE_URL=postgresql://comunicapa:comunicapa_dev_password@postgres:5432/comunicapa_db

# ── Redis ─────────────────────────────────────────────────────────────────────
# Host Redis: "redis" = nome del service Docker Compose in dev
# In prod: hostname o IP del server Redis esterno
REDIS_HOST=redis
REDIS_PORT=6379

# URL completo per BullMQ e altri client Redis.
REDIS_URL=redis://redis:6379

# ── Node ──────────────────────────────────────────────────────────────────────
# development | production | test
NODE_ENV=development

# Livello di log: debug | info | warn | error
LOG_LEVEL=info

# ── Security ──────────────────────────────────────────────────────────────────
# Genera con: openssl rand -hex 32
# JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32

# ── URL pubblici (opzionale) ──────────────────────────────────────────────────
# Base URL pubblica del backend, usata per costruire link nelle email.
# Esempio prod: https://api.comunicapa.example.com
# PUBLIC_BACKEND_URL=http://localhost:8080
