FROM node:22-alpine
RUN apk add --no-cache tzdata
ENV TZ=Europe/Rome
WORKDIR /app
RUN corepack enable && corepack prepare pnpm@latest --activate

# Cache layer: solo i manifesti (prima di COPY . . per sfruttare cache Docker)
COPY package.json pnpm-workspace.yaml .npmrc pnpm.yaml ./
COPY packages/shared-types/package.json ./packages/shared-types/
COPY apps/backend/package.json ./apps/backend/

# Install senza script (evita ERR_PNPM_IGNORED_BUILDS di pnpm v10+)
RUN pnpm install --ignore-scripts

COPY . .

EXPOSE 8080
# Usa il binario direttamente — bypassa il deps-check di pnpm v11 al runtime
WORKDIR /app/apps/backend
CMD ["node_modules/.bin/nest", "start", "--watch"]
